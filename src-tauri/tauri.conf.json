{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Penraft",
  "version": "0.1.0",
  "identifier": "com.penraft.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Penraft",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Local-first Markdown notes and HTML rendering",
    "longDescription": "Penraft manages Markdown notes like macOS Notes, renders Markdown live, and can call local Claude Code or Codex to generate HTML.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown document",
        "role": "Editor",
        "rank": "Alternate",
        "mimeType": "text/markdown"
      }
    ]
  }
}
